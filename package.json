{
  "name": "mcpscan",
  "version": "0.1.0",
  "description": "Security scanner for MCP servers — catches tool poisoning, exfiltration sinks, and supply-chain risk before you install.",
  "type": "module",
  "bin": {
    "mcpscan": "dist/cli.js"
  },
  "files": ["dist", "rules-data"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "discover": "node dist/discover.js",
    "scan-batch": "node dist/scan-batch.js",
    "build-site": "node dist/build-site.js",
    "test": "vitest run",
    "lint": "biome check src test",
    "format": "biome format --write src test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "execa": "^9.5.0",
    "picocolors": "^1.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
