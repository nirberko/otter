{
  "name": "@nirberko/otter",
  "version": "1.6.0",
  "description": "Security scanner for MCP servers — catches tool poisoning, exfiltration sinks, and supply-chain risk before you install.",
  "license": "Apache-2.0",
  "author": "Nir Berko",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nirberko/otter.git"
  },
  "homepage": "https://nirberko.github.io/otter/",
  "bugs": "https://github.com/nirberko/otter/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "security",
    "scanner",
    "supply-chain",
    "tool-poisoning",
    "sarif",
    "llm",
    "ai-security"
  ],
  "bin": {
    "otter": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen:version": "node scripts/gen-version.mjs",
    "prebuild": "node scripts/gen-version.mjs",
    "pretest": "node scripts/gen-version.mjs",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "discover": "node dist/discover.js",
    "scan-batch": "node dist/scan-batch.js",
    "classify": "node dist/classify-officiality.js",
    "summarize": "node dist/summarize.js",
    "build-site": "node dist/build-site.js",
    "test": "vitest run",
    "lint": "biome check src test",
    "format": "biome format --write src test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "execa": "^10.0.0",
    "picocolors": "^1.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.0.0",
    "semantic-release": "^24.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
